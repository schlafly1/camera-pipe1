# Copy this file to .env and fill in your camera RTSP URLs.
# .env is gitignored and never committed.

RTSP_URL_CAM1=rtsp://user:password@192.168.x.x:554/stream
RTSP_URL_CAM2=rtsp://user:password@192.168.x.x:554/stream
RTSP_URL_CAM3=rtsp://user:password@192.168.x.x:554/stream
RTSP_URL_CAM4=rtsp://user:password@192.168.x.x:554/stream

# Set to 4 to force TCP transport (for cameras that block UDP RTP).
# Leave unset or 0 for default UDP with automatic TCP fallback.
# RTSP_TRANSPORT_CAM3=4
# RTSP_TRANSPORT_CAM4=4
