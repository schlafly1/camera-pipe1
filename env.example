# Copy this file to .env and fill in your camera RTSP URLs.
# .env is gitignored and never committed.

RTSP_URL_CAM1=rtsp://user:password@192.168.x.x:554/stream
RTSP_URL_CAM2=rtsp://user:password@192.168.x.x:554/stream
RTSP_URL_CAM3=rtsp://user:password@192.168.x.x:554/stream
RTSP_URL_CAM4=rtsp://user:password@192.168.x.x:554/stream

# Set to 4 to force TCP transport for cameras that block UDP RTP.
# Leave unset or 0 for default UDP. Dahua cameras often require TCP.
# RTSP_TRANSPORT_CAM1=4
# RTSP_TRANSPORT_CAM2=4
# RTSP_TRANSPORT_CAM3=4
# RTSP_TRANSPORT_CAM4=4

# VLM model used for scene descriptions (default: gemma4:26b).
# Override to switch all cameras at once. Must be pulled with `ollama pull`.
# VLM_MODEL=nemotron3:33b
VLM_MODEL=gemma4:26b

# Ollama host — change to a remote Jetson IP to offload VLM inference off this device.
# The remote Jetson must be running `OLLAMA_HOST=0.0.0.0 ollama serve`
# and have the models pulled: ollama pull gemma4:26b && ollama pull nomic-embed-text
# OLLAMA_HOST=http://192.168.x.x:11434
OLLAMA_HOST=http://localhost:11434

# X11 display — :1 is the Jetson's local display when accessed over SSH.
# Run `xhost +local:` on the host before starting containers.
DISPLAY=:1
